generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  pending
  preparing
  delivery
  done
}

enum PaymentMethod {
  pix_online
  pix_on_delivery
  credit_card
  debit_card
  cash
}

model Store {
  id         Int        @id @default(autoincrement())
  name       String
  slug       String     @unique
  ownerUserId Int?
  logoUrl    String?
  preparationTime String?
  primaryColor String?
  secondaryColor String?
  tertiaryColor String?
  trialEndsAt DateTime?
  subscriptionStatus String @default("trial")
  isOpen     Boolean    @default(true)
  operatingHours Json?
  deliveryFee Decimal   @default(0) @db.Decimal(10, 2)
  deliveryRadius Decimal @default(15) @db.Decimal(10, 2)
  storeLatitude Decimal? @db.Decimal(10, 7)
  storeLongitude Decimal? @db.Decimal(10, 7)
  pixKey     String?
  pixReceiverName String?
  pixCity    String?
  acceptsPixOnline Boolean @default(true)
  acceptsPixOnDelivery Boolean @default(true)
  acceptsCreditCard Boolean @default(true)
  acceptsDebitCard Boolean @default(true)
  acceptsCash Boolean @default(true)
  createdAt  DateTime   @default(now())
  owner      User?      @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  categories Category[]
  products   Product[]
  orders     Order[]
  addons     Addon[]

  @@index([slug])
  @@index([ownerUserId])
}

model User {
  id             Int       @id @default(autoincrement())
  fullName       String
  email          String    @unique
  passwordHash   String
  phone          String    @default("")
  documentNumber String    @default("")
  legalName      String    @default("")
  billingZip     String    @default("")
  billingStreet  String    @default("")
  billingNumber  String    @default("")
  billingNeighborhood String @default("")
  billingCity    String    @default("")
  billingState   String    @default("")
  createdAt      DateTime  @default(now())
  stores         Store[]
}

model Category {
  id       Int       @id @default(autoincrement())
  name     String
  storeId  Int
  store    Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  products Product[]
  addons   Addon[]

  @@index([storeId])
}

model Product {
  id               Int        @id @default(autoincrement())
  name             String
  description      String     @db.Text
  price            Decimal    @db.Decimal(10, 2)
  promotionalPrice Decimal?   @db.Decimal(10, 2)
  isPromotion      Boolean    @default(false)
  promotionEnd     DateTime?
  isFeatured       Boolean    @default(false)
  salesCount       Int        @default(0)
  image            String
  categoryId       Int?
  storeId          Int
  createdAt        DateTime   @default(now())
  category         Category?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  store            Store      @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems       OrderItem[]
  addons           ProductAddon[]

  @@index([storeId])
  @@index([categoryId])
}

model Order {
  id            Int         @id @default(autoincrement())
  storeId       Int
  customerName  String
  customerPhone String
  paymentMethod PaymentMethod @default(cash)
  paymentStatus String?
  paymentDetail String?
  pixCopyPaste  String?     @db.Text
  needsChange   Boolean     @default(false)
  changeFor     Decimal?    @db.Decimal(10, 2)
  customerCep   String?
  customerStreet String?
  customerNumber String?
  customerNeighborhood String?
  customerCity String?
  customerState String?
  customerComplement String?
  customerLatitude Decimal? @db.Decimal(10, 7)
  customerLongitude Decimal? @db.Decimal(10, 7)
  customerMapsLink String?
  deliveryFee   Decimal   @default(0) @db.Decimal(10, 2)
  total         Decimal     @db.Decimal(10, 2)
  status        OrderStatus @default(pending)
  createdAt     DateTime    @default(now())
  store         Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderItems    OrderItem[]

  @@index([storeId])
  @@index([status])
}

model OrderItem {
  id        Int      @id @default(autoincrement())
  orderId   Int
  productId Int
  quantity  Int
  price     Decimal  @db.Decimal(10, 2)
  observation String?
  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)
  addons    OrderItemAddon[]

  @@index([orderId])
  @@index([productId])
}

model Addon {
  id              Int              @id @default(autoincrement())
  storeId         Int
  name            String
  price           Decimal          @db.Decimal(10, 2)
  categoryId      Int?
  store           Store            @relation(fields: [storeId], references: [id], onDelete: Cascade)
  category        Category?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  products        ProductAddon[]
  orderItemAddons OrderItemAddon[]

  @@index([storeId])
  @@index([categoryId])
}

model ProductAddon {
  productId Int
  addonId   Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  addon     Addon   @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@id([productId, addonId])
}

model OrderItemAddon {
  id          Int       @id @default(autoincrement())
  orderItemId Int
  addonId     Int
  name        String
  price       Decimal   @db.Decimal(10, 2)
  quantity    Int       @default(1)
  orderItem   OrderItem @relation(fields: [orderItemId], references: [id], onDelete: Cascade)
  addon       Addon     @relation(fields: [addonId], references: [id], onDelete: Restrict)

  @@index([orderItemId])
}
